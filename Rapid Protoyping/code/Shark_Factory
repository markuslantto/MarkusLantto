        fill_solid(leds, NUM_LEDS, CRGB::White);
        FastLED.show();
        return;
    }
    if (buttonPressCount == 4) {
          
            for (int i = 0; i < NUM_LEDS && RedLed>0; i++ && RedLed--) {
                FastLED.clear();
                leds[i]= CRGB::Red;
                FastLED.show();
                delay(100);
                }
                return;
                }
