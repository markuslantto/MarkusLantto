String solveMaze ( int start , int end , int & heading ) {
int queue [ MAX_NODES ] , parent [ MAX_NODES ];
bool visited [ MAX_NODES ];
int head = 0 , tail = 0;

for ( int i =0; i < MAX_NODES ; i ++) { visited [ i ] = false ; parent [ i
] = -1; }

queue [ tail ++] = start ; visited [ start ] = true ;

bool found = false ;
while ( head < tail ) {
int curr = queue [ head ++];
if ( curr == end ) { found = true ; break ; }


for ( int dir =0; dir <4; dir ++) {
int neighbor = mazeMap [ curr ][ dir ];
if ( neighbor != -1 && ! visited [ neighbor ]) {
visited [ neighbor ] = true ; parent [ neighbor ] = curr ;
queue [ tail ++] = neighbor ;
}
}
}

if (! found ) return "";

int path [50]; int count = 0; int curr = end ;
while ( curr != -1) { path [ count ++] = curr ; curr = parent [ curr
]; }

// --- CHANGED : APPEND NODES TO GLOBAL ARRAY WITHOUT
OVERWRITING ---
// We skip the first node ( k =1 instead of k =0) for chained
segments
// so we don ’ t record the connecting node twice ( e . g . 0..29 ,
29..26)
// UNLESS it is the very first segment ( nodeFillIndex == 0) .

int startK = ( nodeFillIndex == 0) ? 0 : 1;

for ( int k = startK ; k < count ; k ++) {
// Logic : path array is backwards ( End - > Start ) , so we
read it in reverse
pathNodeIDs [ nodeFillIndex ++] = path [ count - 1 - k ];
}

String strPath = "";
int currentHeading = heading ; // Use the heading passed from
setup

// Generate Path String
for ( int i = count - 2; i >= 0; i - -) {
int from = path [ i +1]; int to = path [ i ];
int travelDir = -1;

if ( mazeMap [ from ][ NORTH ] == to ) travelDir = NORTH ;
else if ( mazeMap [ from ][ EAST ] == to ) travelDir = EAST ;
else if ( mazeMap [ from ][ SOUTH ] == to ) travelDir = SOUTH ;
else if ( mazeMap [ from ][ WEST ] == to ) travelDir = WEST ;

int diff = travelDir - currentHeading ;
if ( diff < 0) diff += 4;

if ( diff == 0) strPath += " S ";
else if ( diff == 1) strPath += " R ";
else if ( diff == 3) strPath += " L ";
else if ( diff == 2) strPath += " U ";

currentHeading = travelDir ; // Update local tracking
}

// --- VITAL : Update the global heading for the next function
call ---
heading = currentHeading ;

return strPath ;
}
